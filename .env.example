# .env.example
# ====================================================================
# What this file is: a checked-in template of the environment vars
#   Innova needs to run. The real .env (gitignored) is a copy of this
#   file. The example values below are DEMO defaults — fine to use
#   locally as-is, NEVER to use in production.
#
# Why it exists: a non-coder operator clones the repo and runs
#   `cp .env.example .env` as part of the quickstart. With the values
#   below, the app boots without any further configuration.
# ====================================================================

# DATABASE_URL — where Prisma reads/writes the SQLite file.
# The path is interpreted relative to the directory containing the
# `schema.prisma` file (i.e. `./prisma/`), so `file:./dev.db` resolves
# to `./prisma/dev.db` at the project root. Do NOT write
# `file:./prisma/dev.db` here — that would resolve to the (wrong)
# nested `./prisma/prisma/dev.db`.
DATABASE_URL="file:./dev.db"

# AUTH_SECRET — used by Auth.js to sign the JWT session cookies.
# In a real deployment this would be a cryptographically random
# string. For the local demo, a fixed string is fine because:
#   - The app is local-only (no public URL).
#   - The seeded accounts are also demo-only.
# Generate a real one with: `openssl rand -base64 32`
AUTH_SECRET="innova-demo-secret-do-not-use-in-prod"
