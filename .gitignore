# Innova .gitignore
# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# claude code local config
.claude/

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# but DO commit the example template so the operator can copy it
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# innova — local state that must never be committed
# SQLite database file + WAL journal (recreated by `npm run db:reset`)
/prisma/dev.db
/prisma/dev.db-journal
# uploaded attachments live outside public/, so static serving cannot
# leak them; they're per-environment and not part of source
/uploads/

# test artifacts (recreated on every run)
/playwright-report/
/test-results/
